{
  "version": 2,
  "builds": [
    { "src": "api/*.js", "use": "@vercel/node" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "functions": {
    "api/briefs.js":  { "maxDuration": 30 },
    "api/news.js":    { "maxDuration": 30 },
    "api/analyze.js": { "maxDuration": 30 }
  }
}
